{{- $lang := "en" -}}
{{- with .Identity -}}
  {{- with .traits -}}
    {{- if eq (index . "language") "id" -}}{{- $lang = "id" -}}
    {{- else if eq (index . "language") "zh" -}}{{- $lang = "zh" -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- if eq $lang "id" -}}
Gunakan kode ini untuk memverifikasi email Anda:

{{ .VerificationCode }}

Kode ini kedaluwarsa dalam 1 jam.
{{- else if eq $lang "zh" -}}
使用此验证码验证您的邮箱：

{{ .VerificationCode }}

该验证码将在 1 小时后失效。
{{- else -}}
Use this code to verify your email:

{{ .VerificationCode }}

This code expires in 1 hour.
{{- end -}}
