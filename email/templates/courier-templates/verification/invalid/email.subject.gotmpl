{{- $lang := "en" -}}
{{- with .TransientPayload -}}
    {{- if eq (printf "%v" (index . "language")) "id" -}}{{- $lang = "id" -}}
    {{- else if eq (printf "%v" (index . "language")) "zh" -}}{{- $lang = "zh" -}}
    {{- end -}}
{{- end -}}
{{- if eq $lang "id" -}}
Permintaan verifikasi email untuk Klawu
{{- else if eq $lang "zh" -}}
Klawu 邮箱验证请求
{{- else -}}
Email verification request for Klawu
{{- end -}}
