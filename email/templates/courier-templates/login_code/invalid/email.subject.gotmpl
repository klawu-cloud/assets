{{- $lang := "en" -}}
{{- with .TransientPayload -}}
    {{- if eq (printf "%v" (index . "language")) "id" -}}{{- $lang = "id" -}}
    {{- else if eq (printf "%v" (index . "language")) "zh" -}}{{- $lang = "zh" -}}
    {{- end -}}
{{- end -}}
{{- if eq $lang "id" -}}
Permintaan kode masuk untuk akun Klawu Anda
{{- else if eq $lang "zh" -}}
您的 Klawu 账户有登录验证码请求
{{- else -}}
A sign-in code was requested for your Klawu account
{{- end -}}
