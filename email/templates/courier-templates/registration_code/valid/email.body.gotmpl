{{ define "_header" }}
<meta name="color-scheme" content="light dark">
<meta name="supported-color-schemes" content="light dark">
<style>
  :root { color-scheme: light dark; supported-color-schemes: light dark; }
  .email-bg { background: #f6f7fb !important; }
  .email-card { background: #ffffff !important; border: 1px solid #e5e7eb !important; }
  .email-body { color: #111827 !important; }
  .email-muted { color: #6b7280 !important; }
  .email-button { background: #f97316 !important; color: #ffffff !important; }
  @media (prefers-color-scheme: dark) {
    .email-bg { background: #0b1220 !important; }
    .email-card { background: #111827 !important; border-color: #374151 !important; }
    .email-body { color: #f3f4f6 !important; }
    .email-muted { color: #9ca3af !important; }
    .email-button { background: #fb923c !important; color: #111827 !important; }
  }
  [data-ogsc] .email-bg, [data-ogsb] .email-bg { background: #0b1220 !important; }
  [data-ogsc] .email-card, [data-ogsb] .email-card { background: #111827 !important; border-color: #374151 !important; }
  [data-ogsc] .email-body, [data-ogsb] .email-body { color: #f3f4f6 !important; }
  [data-ogsc] .email-muted, [data-ogsb] .email-muted { color: #9ca3af !important; }
  [data-ogsc] .email-button, [data-ogsb] .email-button { background: #fb923c !important; color: #111827 !important; }
</style>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" class="email-bg" style="background:#f6f7fb;padding:24px 0;font-family:Arial,Helvetica,sans-serif;">
  <tr><td align="center">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" class="email-card" style="max-width:600px;width:100%;background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">
      <tr><td style="padding:24px 24px 8px 24px;"><img src="https://cdn.jsdelivr.net/gh/klawu-cloud/assets@main/email/branding/logos/klawu-logo-primary.png" alt="Klawu" width="126" height="28" style="display:block;height:auto;width:126px;max-width:100%;" /></td></tr>
      <tr><td class="email-body" style="padding:0 24px 24px 24px;color:#111827;font-size:14px;line-height:1.6;">
{{ end }}
{{ define "_footer" }}
{{- $footerLang := "en" -}}
{{- with .Traits -}}
  {{- with index . "language" -}}
    {{- if eq . "id" -}}{{- $footerLang = "id" -}}
    {{- else if eq . "zh" -}}{{- $footerLang = "zh" -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
        <p class="email-muted" style="margin:24px 0 0 0;color:#6b7280;font-size:12px;">
          {{- if eq $footerLang "id" -}}Jika Anda tidak meminta ini, Anda dapat mengabaikan email ini dengan aman.
          {{- else if eq $footerLang "zh" -}}如果这不是您本人请求的，您可以放心忽略这封邮件。
          {{- else -}}If you did not request this, you can safely ignore this email.
          {{- end -}}
        </p>
      </td></tr>
    </table>
  </td></tr>
</table>
{{ end }}

{{- $lang := "en" -}}
{{- with .Traits -}}
  {{- with index . "language" -}}
    {{- if eq . "id" -}}{{- $lang = "id" -}}
    {{- else if eq . "zh" -}}{{- $lang = "zh" -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{ template "_header" . }}
{{- if eq $lang "id" -}}
<h2 style="margin:0 0 12px 0;font-size:22px;line-height:1.3;">Selesaikan pendaftaran akun</h2>
<p style="margin:0 0 16px 0;">Gunakan kode berikut untuk menyelesaikan pendaftaran akun Klawu Anda:</p>
{{- else if eq $lang "zh" -}}
<h2 style="margin:0 0 12px 0;font-size:22px;line-height:1.3;">完成账户注册</h2>
<p style="margin:0 0 16px 0;">使用以下验证码完成您的 Klawu 账户注册：</p>
{{- else -}}
<h2 style="margin:0 0 12px 0;font-size:22px;line-height:1.3;">Complete account registration</h2>
<p style="margin:0 0 16px 0;">Use this code to complete your Klawu account registration:</p>
{{- end -}}

<p style="margin:0 0 16px 0;font-size:28px;font-weight:700;letter-spacing:4px;color:#f97316;">{{ .RegistrationCode }}</p>
{{- if eq $lang "id" -}}
<p class="email-muted" style="margin:0;color:#6b7280;">Kode ini kedaluwarsa dalam {{ .ExpiresInMinutes }} menit.</p>
{{- else if eq $lang "zh" -}}
<p class="email-muted" style="margin:0;color:#6b7280;">该验证码将在 {{ .ExpiresInMinutes }} 分钟后失效。</p>
{{- else -}}
<p class="email-muted" style="margin:0;color:#6b7280;">This code expires in {{ .ExpiresInMinutes }} minutes.</p>
{{- end -}}
{{ template "_footer" . }}
